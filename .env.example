# Taiwan WRF Forecast Pipeline — Environment Variables
# Copy this file to .env and fill in the values you need.
# Most variables are optional — the pipeline degrades gracefully.

# ── CWA Open Data API (optional) ────────────────────────────────────────────
# Required for: live observations, tide forecasts, township forecasts, warnings
# Get your key at: https://opendata.cwa.gov.tw/
CWA_OPENDATA_KEY=

# ── Anthropic API (optional) ────────────────────────────────────────────────
# Required for: AI forecast summary generation
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Firebase (optional) ─────────────────────────────────────────────────────
# Required for: WRF summary storage, accuracy log, GRIB2 archive, pipeline health
FIREBASE_PROJECT=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SA_KEY=                        # JSON service account key (base64 or raw)
GOOGLE_APPLICATION_CREDENTIALS=         # Path to service account key file

# ── Notification Services (optional) ────────────────────────────────────────
# Required for: threshold-based forecast alerts
LINE_NOTIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Vercel Deployment (CI/CD only) ──────────────────────────────────────────
# Required for: automated deployment from GitHub Actions
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
